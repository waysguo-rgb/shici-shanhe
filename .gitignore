# Node.js
node_modules/
dist/

# 音频文件 (33MB, 由 tools/generate_doubao_tts.py 生成)
public/assets/audio/

# 大文件
*.mp4
*.webm
*.gif

# 图片 (非代码资源)
*.jpg
*.jpeg
*.png
# 但是 textures/ 下的纹理图是项目资源, 必须入库
!public/assets/textures/*.png
!public/assets/textures/*.jpg

# Python 缓存
__pycache__/
*.pyc

# 构建/日志
*.log

# Claude Code
.vframes/
.claude/settings.local.json
.claude/scheduled_tasks.lock

# 编辑器
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# 旧版备份
legacy/

# 微信小程序 (独立子项目)
miniprogram/

# 外部 corpus (~400MB, 由 tools/enrich_quantangshi.py 等离线处理用, 不入库)
chinese-poetry-master/

# git worktree (Claude Code 自动产生的隔离工作区, 元数据 git 已管理, 工作目录不入主仓库)
.claude/worktrees/

# 用户私人 Excel 资料
*.xlsx

# tools/ 调试/中间产物 (诗词正文核对生成的临时文件, 重新跑 extract 即可)
tools/_pending_*.json
tools/miss_report.json
tools/probed_lines.json
